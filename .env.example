### LLM Engine Selection
# Options: ollama, openai, vllm, lmstudio, llamacpp
LLM_ENGINE=ollama

### Provider Base URLs
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1
VLLM_BASE_URL=http://localhost:8000/v1
LLAMA_CPP_BASE_URL=http://localhost:8080/v1
OPENAI_BASE_URL=https://api.openai.com/v1

### API Keys
OPENAI_API_KEY=sk-no-key-required

### Models
LLM_MODEL=qwen3.5:9b
EMBEDDING_MODEL=qwen3-embedding:8b
VISION_MODEL=qwen2.5vl:latest

### Reranker
# Cohere API (recommended)
RERANKER_BASE_URL=https://api.cohere.com/v2
RERANKER_MODEL=rerank-v4.0-fast
RERANKER_API_KEY=your-cohere-api-key
# Local model fallback (no API key needed, slower)
# RERANKER_BASE_URL=
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

### LLM Settings
LLM_NUM_CTX=32768
LLM_TIMEOUT=7200
LLM_MAX_ASYNC=1

### Embedding Settings
EMBEDDING_DIM=4096
MAX_EMBED_TOKENS=8192
EMBEDDING_TIMEOUT=300
EMBEDDING_MAX_ASYNC=1

### Document Chunking
CHUNK_SIZE=600
CHUNK_OVERLAP_SIZE=100

### Document Parser
# Options: mineru, pypdf
PARSER=mineru

### Storage Paths (inside container)
WORKING_DIR=/app/data/rag_storage
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/output

### Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
